# ============================================
# Human.online API 环境变量配置
# ============================================
# 使用方法：
# 1. 复制此文件为 .env:  cp .env.example .env
# 2. 修改 .env 中的配置值
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中）
# ============================================

# 基础配置
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/humanonline
MONGODB_URL=mongodb://localhost:27017/humanonline
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM 配置 - 至少配置一个
# ============================================
# 默认使用的 LLM 提供商: openai | kimi | deepseek
DEFAULT_LLM_PROVIDER=deepseek

# --- OpenAI (推荐) ---
# 获取 API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# --- Kimi (Moonshot - 中文优化) ---
# 获取 API Key: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshot-v1-32k

# --- DeepSeek (性价比高，国内可用) ---
# 获取 API Key: https://platform.deepseek.com/
# DeepSeek 是目前性价比最高的选择，中文效果也很好
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat  # 可选: deepseek-chat, deepseek-coder, deepseek-reasoner

# --- Anthropic Claude (可选) ---
# ANTHROPIC_API_KEY=your-anthropic-key

# ============================================
# Google OAuth 配置 (用于用户登录)
# ============================================
# 1. 访问 https://console.cloud.google.com/
# 2. 创建项目并启用 Google+ API
# 3. 创建 OAuth 2.0 客户端 ID
# 4. 添加授权重定向 URI:
#    - 本地开发: http://localhost:3000/auth/login
#    - 自定义域名: http://yourdomain.com:3000/auth/login

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth 回调地址（必须与 Google Console 中配置的一致）
# 本地开发:
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/login
# 自定义域名部署（示例）:
# GOOGLE_REDIRECT_URI=http://humind.life:3000/auth/login
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/login

# ============================================
# 前端配置 (用于 CORS)
# ============================================
# 允许的跨域域名列表（JSON 数组格式）
#
# 本地开发:
ALLOWED_ORIGINS=["http://localhost:3000"]
#
# 自定义域名部署（示例）:
# ALLOWED_ORIGINS=["http://localhost:3000","https://humind.life","http://humind.life:3000","https://humind.life:3000"]
# ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com","http://yourdomain.com:3000"]

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=/tmp/humanonline/uploads
